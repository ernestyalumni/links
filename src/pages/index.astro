---
import siteConfig from '../../config/site.config.json';
import linksData from '../../data/links.json';
import { resolveTheme } from '../themes/themes';

const { site, profile, theme: themeCfg, footer, analytics, social_meta } = siteConfig;
const theme = resolveTheme(themeCfg?.preset ?? 'academic');
const colorScheme = themeCfg?.color_scheme ?? 'auto';

const links = (linksData.links || [])
  .slice()
  .sort((a, b) => a.position - b.position);

// Build :root CSS from theme palette
const fontFamily = `${themeCfg?.fonts?.primary ? `'${themeCfg.fonts.primary}',` : ''} ${themeCfg?.fonts?.fallback ?? theme.font_family}`.trim();

function cssVars(vars: Record<string, string>): string {
  return Object.entries(vars).map(([k, v]) => `  ${k}: ${v};`).join('\n');
}

const lightBlock = `:root { color-scheme: light;\n${cssVars(theme.light)}\n}`;
const darkBlock =
  colorScheme === 'dark'
    ? `:root { color-scheme: dark;\n${cssVars(theme.dark)}\n}`
    : colorScheme === 'auto'
    ? `@media (prefers-color-scheme: dark) {\n  :root { color-scheme: dark;\n${cssVars(theme.dark)}\n  }\n}`
    : '';

const rootBlock = colorScheme === 'dark' ? darkBlock : `${lightBlock}\n${darkBlock}`;
---

<!doctype html>
<html lang={site.language ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.title}</title>
    <meta name="description" content={site.description} />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:type" content="website" />
    {site.url && <meta property="og:url" content={site.url} />}
    {social_meta?.og_image && <meta property="og:image" content={social_meta.og_image} />}
    {social_meta?.twitter_card && (
      <meta name="twitter:card" content={social_meta.twitter_card} />
    )}
    {site.favicon && <link rel="icon" type="image/svg+xml" href={site.favicon} />}
    {theme.fonts_url && (
      <>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href={theme.fonts_url} rel="stylesheet" />
      </>
    )}
    {analytics?.provider === 'plausible' && analytics.domain && (
      <script defer is:inline src={analytics.script_url ?? `https://plausible.io/js/script.js`} data-domain={analytics.domain}></script>
    )}
    {analytics?.provider === 'umami' && analytics.script_url && analytics.domain && (
      <script defer is:inline src={analytics.script_url} data-website-id={analytics.domain}></script>
    )}
  </head>
  <body>
    <main class="page">
      <header class="profile">
        {profile.show_avatar && profile.avatar && (
          <img src={profile.avatar} alt={`${profile.display_name} avatar`} class="avatar" loading="eager" />
        )}
        <h1 class="display-name">{profile.display_name}</h1>
        {profile.show_handle && profile.handle && <p class="handle">@{profile.handle}</p>}
        {profile.show_tagline && profile.tagline && <p class="tagline">{profile.tagline}</p>}
      </header>

      {links.length === 0 ? (
        <p class="empty">No links yet. Edit <code>data/links.json</code> to add some.</p>
      ) : (
        <ul class="links" role="list">
          {links.map((link) => (
            <li class="link-item">
              <a
                href={link.url}
                class={`link${link.highlight ? ' link--highlight' : ''}`}
                rel="noopener"
                target="_blank"
                data-link-id={link.id}
              >
                {link.icon && <span class="link-icon" aria-hidden="true">{link.icon}</span>}
                <span class="link-title">{link.title}</span>
              </a>
            </li>
          ))}
        </ul>
      )}

      {footer?.show && (
        <footer class="colophon">
          {footer.credit && <p set:html={footer.credit}></p>}
          {footer.show_powered_by && (
            <p class="powered-by">
              <em>Powered by <a href="https://github.com/ernestyalumni/links">links</a> — an open-source Linktree alternative</em>
            </p>
          )}
        </footer>
      )}
    </main>

    <style is:global set:html={`
      ${rootBlock}

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: ${fontFamily};
        font-size: 19px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .page {
        max-width: 640px;
        margin: 0 auto;
        padding: 4rem 1.5rem 3rem;
      }

      .profile {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--rule);
      }

      .avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--rule);
        margin-bottom: 1.25rem;
        background: var(--link-bg);
      }

      .display-name {
        font-size: 2.25rem;
        font-weight: 500;
        letter-spacing: 0.01em;
        margin: 0 0 0.25rem;
        line-height: 1.2;
      }

      .handle {
        margin: 0 0 0.75rem;
        color: var(--ink-muted);
        font-style: italic;
        font-size: 1.05rem;
      }

      .tagline {
        margin: 0;
        color: var(--ink-soft);
        font-size: 1.1rem;
        font-style: italic;
        letter-spacing: 0.005em;
      }

      .empty {
        text-align: center;
        color: var(--ink-muted);
        font-style: italic;
      }

      .links {
        list-style: none;
        padding: 0;
        margin: 0 0 3rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }

      .link {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 1rem 1.25rem;
        background: var(--link-bg);
        border: 1px solid var(--rule);
        border-radius: 4px;
        color: var(--ink);
        text-decoration: none;
        font-size: 1.1rem;
        transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
      }

      .link:hover, .link:focus-visible {
        background: var(--link-bg-hover);
        border-color: var(--accent);
        outline: none;
      }

      .link:focus-visible {
        box-shadow: 0 0 0 2px var(--accent);
      }

      .link--highlight {
        border-color: var(--accent);
        border-width: 2px;
        font-weight: 600;
      }

      .link-icon {
        font-size: 1.25rem;
        line-height: 1;
        flex: 0 0 auto;
      }

      .link-title {
        flex: 1 1 auto;
      }

      .colophon {
        text-align: center;
        color: var(--ink-muted);
        font-size: 0.95rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--rule);
      }

      .colophon p {
        margin: 0.25rem 0;
      }

      .colophon a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px dotted var(--accent);
      }

      .colophon a:hover {
        border-bottom-style: solid;
      }

      .powered-by {
        font-size: 0.85rem;
        opacity: 0.7;
      }

      code {
        font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
        font-size: 0.92em;
        background: var(--link-bg);
        padding: 0.1em 0.35em;
        border-radius: 3px;
        border: 1px solid var(--rule);
      }

      ${theme.extra_css ?? ''}
    `}>
    </style>
  </body>
</html>
