---
import linksData from '../../data/links.json';

const profile = linksData.profile;
const links = (linksData.links || []).slice().sort((a, b) => a.position - b.position);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{profile.display_name} — Links</title>
    <meta name="description" content={profile.tagline} />
    <meta property="og:title" content={`${profile.display_name} — Links`} />
    <meta property="og:description" content={profile.tagline} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main class="page">
      <header class="profile">
        {profile.show_avatar && profile.avatar && (
          <img src={profile.avatar} alt={`${profile.display_name} avatar`} class="avatar" />
        )}
        <h1 class="display-name">{profile.display_name}</h1>
        <p class="handle">@{profile.handle}</p>
        <p class="tagline">{profile.tagline}</p>
      </header>

      {links.length === 0 ? (
        <p class="empty">No links yet. Edit <code>data/links.json</code> to add some.</p>
      ) : (
        <ul class="links" role="list">
          {links.map((link) => (
            <li class="link-item">
              <a href={link.url} class="link" rel="noopener" target="_blank">
                {link.icon && <span class="link-icon" aria-hidden="true">{link.icon}</span>}
                <span class="link-title">{link.title}</span>
              </a>
            </li>
          ))}
        </ul>
      )}

      <footer class="colophon">
        <p>
          <em>Curated as a static page · open source on
            <a href="https://github.com/ernestyalumni/links">GitHub</a></em>
        </p>
      </footer>
    </main>

    <style is:global>
      :root {
        --paper: #fbfaf6;
        --ink: #1a1a1a;
        --ink-soft: #4a4a4a;
        --ink-muted: #7a7a7a;
        --rule: #d8d4c7;
        --link-bg: #ffffff;
        --link-bg-hover: #f4efe1;
        --accent: #5b3a1f;
        --serif: 'EB Garamond', 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --paper: #15140f;
          --ink: #f0ece0;
          --ink-soft: #c8c4b6;
          --ink-muted: #8a8678;
          --rule: #3a372e;
          --link-bg: #1f1d17;
          --link-bg-hover: #2a2820;
          --accent: #c9a878;
        }
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--serif);
        font-size: 19px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .page {
        max-width: 640px;
        margin: 0 auto;
        padding: 4rem 1.5rem 3rem;
      }

      .profile {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--rule);
      }

      .avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--rule);
        margin-bottom: 1.25rem;
        background: var(--link-bg);
      }

      .display-name {
        font-size: 2.25rem;
        font-weight: 500;
        letter-spacing: 0.01em;
        margin: 0 0 0.25rem;
        line-height: 1.2;
      }

      .handle {
        margin: 0 0 0.75rem;
        color: var(--ink-muted);
        font-style: italic;
        font-size: 1.05rem;
      }

      .tagline {
        margin: 0;
        color: var(--ink-soft);
        font-size: 1.1rem;
        font-style: italic;
        letter-spacing: 0.005em;
      }

      .empty {
        text-align: center;
        color: var(--ink-muted);
        font-style: italic;
      }

      .links {
        list-style: none;
        padding: 0;
        margin: 0 0 3rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }

      .link {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 1rem 1.25rem;
        background: var(--link-bg);
        border: 1px solid var(--rule);
        border-radius: 4px;
        color: var(--ink);
        text-decoration: none;
        font-size: 1.1rem;
        transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
      }

      .link:hover, .link:focus-visible {
        background: var(--link-bg-hover);
        border-color: var(--accent);
        outline: none;
      }

      .link:focus-visible {
        box-shadow: 0 0 0 2px var(--accent);
      }

      .link-icon {
        font-size: 1.25rem;
        line-height: 1;
        flex: 0 0 auto;
      }

      .link-title {
        flex: 1 1 auto;
      }

      .colophon {
        text-align: center;
        color: var(--ink-muted);
        font-size: 0.95rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--rule);
      }

      .colophon a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px dotted var(--accent);
      }

      .colophon a:hover {
        border-bottom-style: solid;
      }

      code {
        font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
        font-size: 0.92em;
        background: var(--link-bg);
        padding: 0.1em 0.35em;
        border-radius: 3px;
        border: 1px solid var(--rule);
      }
    </style>
  </body>
</html>
