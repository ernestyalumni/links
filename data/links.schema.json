{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Links",
  "description": "Active links rendered on the page, ordered by `position` ascending.",
  "type": "object",
  "required": ["links"],
  "properties": {
    "links": {
      "type": "array",
      "items": { "$ref": "#/definitions/Link" }
    }
  },
  "definitions": {
    "Link": {
      "type": "object",
      "required": ["id", "title", "url", "position"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{0,59}$",
          "description": "Stable kebab-case slug. Never edit after creation."
        },
        "title": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "icon": {
          "type": "string",
          "description": "Optional emoji or simple-icons name (e.g. 'github', 'youtube')."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Free-form labels for grouping/filtering. Optional."
        },
        "position": {
          "type": "integer",
          "minimum": 1,
          "description": "1 = top of list."
        },
        "added_at": {
          "type": "string",
          "format": "date"
        },
        "click_estimate": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional historical click count carried over from another platform."
        },
        "highlight": {
          "type": "boolean",
          "description": "Visual emphasis (theme-dependent).",
          "default": false
        }
      },
      "additionalProperties": false
    }
  }
}
